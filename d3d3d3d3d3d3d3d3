<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#f5f2ec;
  --black:#0d0d0d;
  --ink:#1a1a1a;
  --mid:#79746a;
  --light:#ece8e0;
  --accent:#d43a1f;
  --accent-dark:#b02f18;
  --border:#e0dbd2;
  --card:#fff;
  --radius:14px;
  --sidebar:320px;
  --nav-h:64px;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:'DM Sans',sans-serif;font-weight:400;line-height:1.6;overflow-x:hidden}
body.sidebar-open{overflow:hidden}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:300;
  height:var(--nav-h);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3rem;
  background:rgba(245,242,236,0.96);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
  transition:box-shadow 0.3s;
}
nav.scrolled{box-shadow:0 2px 20px rgba(0,0,0,0.06)}
.logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.65rem;letter-spacing:0.07em;
  color:var(--black);text-decoration:none;
  display:flex;align-items:baseline;gap:4px;
  cursor:pointer;
}
.logo-dot{
  width:6px;height:6px;background:var(--accent);
  border-radius:50%;flex-shrink:0;margin-bottom:-1px;
}
.nav-right{display:flex;align-items:center;gap:1.5rem}
.nav-enquire{
  background:var(--accent);color:#fff;
  padding:0.55rem 1.3rem;border-radius:100px;
  font-size:0.8rem;font-weight:600;
  border:none;cursor:pointer;font-family:'DM Sans',sans-serif;
  transition:background 0.2s,transform 0.15s;
  letter-spacing:0.02em;
}
.nav-enquire:hover{background:var(--accent-dark);transform:translateY(-1px)}
.burger{
  width:40px;height:40px;border-radius:8px;
  background:transparent;border:1.5px solid var(--border);
  cursor:pointer;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:5px;
  transition:border-color 0.2s,background 0.2s;
}
.burger:hover{border-color:var(--ink);background:var(--light)}
.burger span{
  display:block;width:18px;height:1.5px;
  background:var(--ink);border-radius:2px;
  transition:transform 0.3s,opacity 0.3s,width 0.3s;
  transform-origin:center;
}
.burger.active span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
.burger.active span:nth-child(2){opacity:0;width:0}
.burger.active span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}

/* ── SIDEBAR ── */
.sidebar-overlay{
  position:fixed;inset:0;z-index:400;
  background:rgba(13,13,13,0.5);
  opacity:0;pointer-events:none;
  transition:opacity 0.35s;
  backdrop-filter:blur(3px);
}
.sidebar-overlay.active{opacity:1;pointer-events:all}
.sidebar{
  position:fixed;top:0;right:0;bottom:0;z-index:500;
  width:var(--sidebar);
  background:var(--black);
  transform:translateX(100%);
  transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);
  display:flex;flex-direction:column;
  overflow-y:auto;
}
.sidebar.active{transform:translateX(0)}
.sidebar-top{
  padding:1.5rem 2rem;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid rgba(255,255,255,0.07);
}
.sidebar-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.4rem;letter-spacing:0.07em;color:#fff;
  display:flex;align-items:baseline;gap:3px;
}
.sidebar-logo-dot{width:5px;height:5px;background:var(--accent);border-radius:50%;margin-bottom:-1px}
.sidebar-close{
  width:32px;height:32px;border-radius:6px;
  background:rgba(255,255,255,0.06);border:none;
  color:rgba(255,255,255,0.5);font-size:1rem;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:background 0.2s,color 0.2s;
}
.sidebar-close:hover{background:rgba(255,255,255,0.12);color:#fff}
.sidebar-nav{padding:2rem 0;flex:1}
.sidebar-link{
  display:block;padding:1rem 2rem;
  font-size:0.9rem;font-weight:500;color:rgba(255,255,255,0.45);
  text-decoration:none;cursor:pointer;
  border-left:2px solid transparent;
  transition:color 0.2s,border-color 0.2s,background 0.2s,padding-left 0.2s;
  letter-spacing:0.02em;
}
.sidebar-link:hover,.sidebar-link.active{
  color:#fff;
  border-left-color:var(--accent);
  background:rgba(255,255,255,0.03);
  padding-left:2.5rem;
}
.sidebar-section-label{
  font-size:0.62rem;font-weight:700;letter-spacing:0.16em;
  text-transform:uppercase;color:rgba(255,255,255,0.18);
  padding:0.5rem 2rem 0.3rem;margin-top:1rem;
}
.sidebar-bottom{
  padding:2rem;
  border-top:1px solid rgba(255,255,255,0.07);
}
.sidebar-cta{
  display:block;width:100%;text-align:center;
  padding:0.85rem;background:var(--accent);color:#fff;
  border:none;border-radius:100px;font-size:0.875rem;
  font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;
  transition:background 0.2s;letter-spacing:0.02em;
}
.sidebar-cta:hover{background:var(--accent-dark)}
.sidebar-email{
  text-align:center;margin-top:1rem;
  font-size:0.75rem;color:rgba(255,255,255,0.22);
}
.sidebar-email a{color:rgba(255,255,255,0.4);text-decoration:none}
.sidebar-email a:hover{color:#fff}

/* ── PAGES ── */
.page{display:none}
.page.active{display:block}

/* ── SHARED ── */
.eyebrow{
  font-size:0.68rem;font-weight:700;letter-spacing:0.18em;
  text-transform:uppercase;color:var(--accent);
  margin-bottom:1.2rem;
  display:flex;align-items:center;gap:0.75rem;
}
.eyebrow::before{content:'';width:18px;height:1.5px;background:var(--accent)}
.sh{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2.2rem,4.5vw,4rem);
  line-height:0.95;letter-spacing:0.02em;color:var(--black);
}
.sh .red{color:var(--accent)}
.sh .it{font-family:'DM Serif Display',serif;font-style:italic;letter-spacing:0}
.btn{
  padding:0.85rem 1.8rem;border-radius:100px;
  font-size:0.875rem;font-weight:600;
  text-decoration:none;transition:all 0.2s;
  cursor:pointer;border:none;font-family:'DM Sans',sans-serif;
  letter-spacing:0.02em;display:inline-flex;align-items:center;gap:0.5rem;
}
.btn-red{background:var(--accent);color:#fff}
.btn-red:hover{background:var(--accent-dark);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--border)}
.btn-ghost:hover{border-color:var(--ink)}

/* ── HERO ── */
.hero{
  min-height:100vh;padding-top:var(--nav-h);
  display:grid;grid-template-columns:1.1fr 0.9fr;
  border-bottom:1px solid var(--border);
}
.hero-l{
  padding:6rem 3rem 5rem;
  display:flex;flex-direction:column;justify-content:center;
  border-right:1px solid var(--border);
}
.hero h1{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(4rem,8.5vw,8.5rem);
  line-height:0.88;letter-spacing:0.02em;
  color:var(--black);margin-bottom:2rem;
}
.hero h1 .ghost{-webkit-text-stroke:2.5px var(--black);color:transparent}
.hero h1 .red{color:var(--accent)}
.hero-copy{
  font-size:1rem;color:var(--mid);
  max-width:480px;line-height:1.85;
  margin-bottom:2.5rem;font-weight:300;
}
.hero-copy strong{color:var(--ink);font-weight:500}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.hero-r{
  background:var(--black);
  padding:6rem 2.5rem 5rem;
  display:flex;flex-direction:column;justify-content:center;
  position:relative;overflow:hidden;
}
.hero-r::before{
  content:'';position:absolute;
  top:-100px;right:-100px;
  width:360px;height:360px;
  background:radial-gradient(circle,rgba(212,58,31,0.09) 0%,transparent 70%);
  pointer-events:none;
}
.hr-label{
  font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;
  color:rgba(255,255,255,0.2);margin-bottom:1.8rem;
}
.deal{
  padding:1.8rem 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
}
.deal:last-of-type{border-bottom:none}
.deal-mark{
  width:28px;height:2px;background:var(--accent);margin-bottom:1rem;
}
.deal h3{font-size:0.95rem;font-weight:600;color:#fff;margin-bottom:0.35rem}
.deal p{font-size:0.8rem;color:rgba(255,255,255,0.35);line-height:1.7}
.live{
  display:inline-flex;align-items:center;gap:0.6rem;
  background:rgba(212,58,31,0.08);
  border:1px solid rgba(212,58,31,0.18);
  color:var(--accent);padding:0.45rem 1rem;
  border-radius:100px;font-size:0.68rem;
  font-weight:600;margin-top:2rem;letter-spacing:0.04em;
}
.live::before{
  content:'';width:5px;height:5px;
  background:var(--accent);border-radius:50%;
  animation:pulse 1.8s infinite;
}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.2}}

/* ── TICKER ── */
.ticker{
  background:var(--accent);
  padding:0.72rem 0;overflow:hidden;white-space:nowrap;
}
.tick-track{display:inline-flex;animation:roll 38s linear infinite}
.tick-track span{
  font-family:'Bebas Neue',sans-serif;
  font-size:0.82rem;letter-spacing:0.14em;
  color:rgba(255,255,255,0.82);padding:0 1.5rem;
}
.tick-track .sep{color:rgba(255,255,255,0.3);padding:0 0.2rem}
@keyframes roll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── STATEMENT ── */
.statement{
  padding:7rem 3rem;
  display:grid;grid-template-columns:1fr 1fr;
  gap:8rem;align-items:center;
  border-bottom:1px solid var(--border);
}
.stmt-r p{
  font-size:0.97rem;color:var(--mid);
  line-height:1.9;margin-bottom:1.1rem;font-weight:300;
}
.stmt-r p strong{color:var(--ink);font-weight:500}
.pull{
  font-family:'DM Serif Display',serif;
  font-style:italic;font-size:1.2rem;color:var(--ink);
  border-left:3px solid var(--accent);
  padding-left:1.3rem;margin:2rem 0;line-height:1.55;
}

/* ── WHO WE HELP ── */
.help{padding:6rem 3rem;border-bottom:1px solid var(--border)}
.help-top{
  display:grid;grid-template-columns:1fr 1fr;
  gap:5rem;align-items:end;margin-bottom:3.5rem;
}
.help-top-r{
  font-size:0.95rem;color:var(--mid);
  line-height:1.82;font-weight:300;
}
.help-top-r strong{color:var(--ink);font-weight:500}
.help-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:var(--border);
  border:1px solid var(--border);
  border-radius:var(--radius);overflow:hidden;
}
.hc{
  background:var(--bg);padding:2.2rem;
  transition:background 0.28s;
  position:relative;overflow:hidden;
}
.hc::after{
  content:'';position:absolute;
  bottom:0;left:0;right:0;height:2px;
  background:transparent;transition:background 0.28s;
}
.hc:hover{background:var(--card)}
.hc:hover::after{background:var(--accent)}
.hc.dark{background:var(--black)}
.hc.dark:hover{background:#111}
.hc.dark h3{color:#fff}
.hc.dark p{color:rgba(255,255,255,0.38)}
.hc-tag{
  font-size:0.6rem;font-weight:700;letter-spacing:0.1em;
  text-transform:uppercase;background:var(--accent);color:#fff;
  padding:0.18rem 0.55rem;border-radius:100px;
  display:inline-block;margin-bottom:0.9rem;
}
.hc h3{font-weight:600;font-size:0.95rem;color:var(--ink);margin-bottom:0.5rem}
.hc p{font-size:0.82rem;color:var(--mid);line-height:1.72}
.hc-chips{display:flex;flex-wrap:wrap;gap:0.35rem;margin-top:1.1rem}
.chip{
  background:var(--light);border:1px solid var(--border);
  color:var(--mid);padding:0.2rem 0.65rem;
  border-radius:100px;font-size:0.7rem;font-weight:500;
}
.hc.dark .chip{
  background:rgba(255,255,255,0.06);
  border-color:rgba(255,255,255,0.1);
  color:rgba(255,255,255,0.38);
}
.help-note{
  margin-top:2.5rem;padding:1.5rem 2rem;
  background:var(--light);border-radius:var(--radius);
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  gap:2rem;flex-wrap:wrap;
}
.help-note p{font-size:0.875rem;color:var(--mid);line-height:1.6}
.help-note strong{color:var(--ink)}
.help-note a{color:var(--accent);font-weight:600;text-decoration:none;cursor:pointer}

/* ── HOW ── */
.how{
  padding:6rem 3rem;
  background:var(--black);color:#fff;
  border-bottom:1px solid #1a1a1a;
}
.how .eyebrow{color:rgba(255,255,255,0.28)}
.how .eyebrow::before{background:rgba(255,255,255,0.28)}
.how .sh{color:#fff}
.how-layout{
  display:grid;grid-template-columns:1fr 1fr;
  gap:5rem;margin-top:4.5rem;align-items:start;
}
.step{
  display:grid;grid-template-columns:2.5rem 1fr;
  gap:1.2rem;padding:1.8rem 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
  align-items:start;
}
.step:last-child{border-bottom:none;padding-bottom:0}
.step-n{
  font-family:'Bebas Neue',sans-serif;font-size:0.95rem;
  color:var(--accent);letter-spacing:0.08em;padding-top:3px;
}
.step h3{font-weight:600;font-size:0.92rem;color:#fff;margin-bottom:0.45rem}
.step p{font-size:0.82rem;color:rgba(255,255,255,0.36);line-height:1.75}
.how-r{}
.q-card{
  background:#141414;border:1px solid rgba(255,255,255,0.07);
  border-radius:var(--radius);padding:1.8rem;margin-bottom:0.9rem;
}
.q-card:last-of-type{margin-bottom:0}
.q-lbl{
  font-size:0.6rem;font-weight:700;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem;
}
.q-card h4{font-weight:600;font-size:0.88rem;color:#fff;margin-bottom:0.4rem}
.q-card p{font-size:0.8rem;color:rgba(255,255,255,0.33);line-height:1.65}
.diff{
  background:rgba(212,58,31,0.07);
  border:1px solid rgba(212,58,31,0.16);
  border-radius:var(--radius);padding:1.8rem;margin-top:0.9rem;
}
.diff-lbl{
  font-size:0.6rem;font-weight:700;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--accent);margin-bottom:0.9rem;
}
.diff-row{
  display:flex;gap:1rem;align-items:flex-start;
  padding:0.55rem 0;border-bottom:1px solid rgba(255,255,255,0.05);
}
.diff-row:last-child{border-bottom:none;padding-bottom:0}
.diff-mk{
  font-size:0.75rem;font-weight:600;
  flex-shrink:0;margin-top:1px;
  width:16px;text-align:center;
}
.diff-mk.yes{color:var(--accent)}
.diff-mk.no{color:rgba(255,255,255,0.18)}
.diff-row p{font-size:0.8rem;color:rgba(255,255,255,0.45);line-height:1.6}
.diff-row p strong{color:#fff;font-weight:500}

/* ── PACKAGES ── */
.packages{padding:6rem 3rem;border-bottom:1px solid var(--border)}
.pkg-intro{
  display:grid;grid-template-columns:1fr 1fr;
  gap:5rem;align-items:end;margin-bottom:4rem;
}
.pkg-intro-r p{
  font-size:0.95rem;color:var(--mid);
  line-height:1.82;font-weight:300;margin-bottom:0.75rem;
}
.pkg-intro-r strong{color:var(--ink);font-weight:500}
.pkg-row-label{
  font-size:0.68rem;font-weight:700;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--mid);
  margin-bottom:1.2rem;
  display:flex;align-items:center;gap:1rem;
}
.pkg-row-label::after{
  content:'';flex:1;height:1px;
  background:var(--border);display:inline-block;
}
.pkg-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1.5rem;margin-bottom:4rem;
}
.pk{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:var(--radius);padding:2.2rem;
  position:relative;overflow:hidden;
  transition:transform 0.3s,box-shadow 0.3s,border-color 0.3s;
}
.pk::after{
  content:'';position:absolute;
  bottom:0;left:0;right:0;height:3px;
  background:transparent;transition:background 0.3s;
}
.pk:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,0.08)}
.pk:hover::after,.pk.feat::after{background:var(--accent)}
.pk.feat{background:var(--black);border-color:var(--black)}
.pk-tier{
  font-size:0.62rem;font-weight:700;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--mid);margin-bottom:0.8rem;
}
.pk.feat .pk-tier{color:rgba(255,255,255,0.25)}
.pk-n{
  font-family:'Bebas Neue',sans-serif;font-size:3.8rem;
  line-height:1;letter-spacing:0.02em;color:var(--black);margin-bottom:0.2rem;
}
.pk.feat .pk-n{color:var(--accent)}
.pk-n sub{
  font-family:'DM Sans',sans-serif;font-size:0.88rem;
  font-weight:400;color:var(--mid);letter-spacing:0;
  vertical-align:middle;margin-left:0.2rem;
}
.pk.feat .pk-n sub{color:rgba(255,255,255,0.25)}
.pk-desc{font-size:0.82rem;color:var(--mid);line-height:1.6;margin-bottom:1.5rem}
.pk.feat .pk-desc{color:rgba(255,255,255,0.35)}
.pk-div{height:1px;background:var(--border);margin-bottom:1.2rem}
.pk.feat .pk-div{background:rgba(255,255,255,0.07)}
.pk-list{list-style:none;margin-bottom:1.8rem}
.pk-list li{
  font-size:0.82rem;padding:0.32rem 0;color:var(--ink);
  display:flex;align-items:flex-start;gap:0.65rem;line-height:1.5;
}
.pk.feat .pk-list li{color:rgba(255,255,255,0.58)}
.pk-list li::before{
  content:'';width:14px;height:14px;border-radius:50%;
  flex-shrink:0;margin-top:2px;
  border:1.5px solid var(--accent);
  background:rgba(212,58,31,0.08);
}
.pk-enquire{
  background:var(--bg);border:1.5px dashed var(--border);
  border-radius:10px;padding:1rem;text-align:center;
  margin-bottom:1.1rem;cursor:pointer;transition:all 0.2s;
}
.pk.feat .pk-enquire{background:#161616;border-color:rgba(255,255,255,0.08)}
.pk-enquire:hover{border-color:var(--accent);background:rgba(212,58,31,0.04)}
.pk-enquire p{font-size:0.75rem;color:var(--mid);font-weight:500}
.pk.feat .pk-enquire p{color:rgba(255,255,255,0.28)}
.pk-enquire span{font-size:0.68rem;color:var(--accent);font-weight:600}
.pkbtn{
  display:block;width:100%;text-align:center;
  padding:0.8rem;border-radius:100px;
  font-size:0.82rem;font-weight:600;cursor:pointer;
  border:none;font-family:'DM Sans',sans-serif;transition:all 0.2s;
}
.pb-dark{background:var(--black);color:#fff}
.pb-dark:hover{background:var(--accent)}
